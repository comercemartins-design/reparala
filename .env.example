# ============================================================
# REPARA LÁ — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores
# NUNCA suba o arquivo .env para o GitHub
# ============================================================

# ── SUPABASE ────────────────────────────────────────────────
SUPABASE_URL=https://seu_projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anonima_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ── BANCO DE DADOS (Supabase PostgreSQL) ────────────────────
DATABASE_URL=postgresql://postgres:[SUA_SENHA_DO_BANCO]@db.seu_projeto.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[SUA_SENHA_DO_BANCO]@db.seu_projeto.supabase.co:6543/postgres

# ── API ─────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
JWT_SECRET=gere_uma_string_aleatoria_longa_aqui_minimo_32_chars

# ── ADMIN WEB ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── EXPO (Apps Mobile) ──────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://seu_projeto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_aqui
EXPO_PUBLIC_API_URL=http://localhost:3001
