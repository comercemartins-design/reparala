{
  "name": "@reparala/api",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx prisma generate --schema=prisma/schema.prisma && npx prisma db push --schema=prisma/schema.prisma",
    "start": "npx tsx src/server.ts",
    "generate": "npx prisma generate --schema=../db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@supabase/supabase-js": "^2.39.0",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.1.0",
    "node-cron": "^3.0.3",
    "zod": "^3.22.0",
    "nanoid": "^5.0.0",
    "dotenv": "^16.4.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "prisma": "5.22.0",
    "typescript": "^5.3.0"
  }
}
